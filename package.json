{
  "name": "codemate",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "dev": "APP_VARIANT=development expo start",
    "build:prod:i": "eas build --platform ios --profile production",
    "build:prod:a": "eas build --platform android --profile production",
    "build:preview:i": "eas build --platform ios --profile preview",
    "build:preview:a": "eas build --platform android --profile preview",
    "build:preview": "eas build --profile preview --channel preview",
    "build:prod": "eas build --profile production --channel production",
    "build:dev:i": "APP_VARIANT=development eas build --platform ios --profile development",
    "build:dev:a": "APP_VARIANT=development eas build --platform android --profile development",
    "build:dev": "APP_VARIANT=development eas build --profile development",
    "android": "APP_VARIANT=development expo start --android",
    "ios": "APP_VARIANT=development expo start --ios",
    "web": "APP_VARIANT=development expo start --web",
    "test": "jest --watchAll",
    "lint": "expo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^7.15.5",
